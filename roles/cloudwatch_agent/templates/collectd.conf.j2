# Config file for collectd(1).
# Please read collectd.conf(5) for a list of options.
# http://collectd.org/
#
# {{ ansible_managed }}

##############################################################################
# Global settings for the daemon.                                            #
##############################################################################

Hostname "{{ ansible_hostname }}"
FQDNLookup  false
BaseDir     "{{ collectd_base_dir }}"
PIDFile     "{{ collectd_pid_file }}"
PluginDir   "{{ collectd_plugin_dir }}"
TypesDB     "{{ collectd_types_db }}"

Interval     {{ collectd_interval }}

Timeout      {{ collectd_timeout }}
ReadThreads  {{ collectd_read_threads }}
WriteThreads  {{ collectd_write_threads }}

##############################################################################
# Logging                                                                    #
##############################################################################

{% if collectd_logfile is defined %}
LoadPlugin logfile

<Plugin logfile>
  LogLevel      {{ collectd_log_level }}
  Timestamp     true
  PrintSeverity true
</Plugin>

{% else %}
LoadPlugin syslog
<Plugin syslog>
  LogLevel {{ collectd_log_level }}
</Plugin>
{% endif %}

##############################################################################
# LoadPlugin section                                                         #
##############################################################################

LoadPlugin cpu
LoadPlugin interface
LoadPlugin load
LoadPlugin memory

# Include all configuration files in collectd.d
Include "/etc/collectd.d/*.conf"
